# Copia questo file in `.env.local` per lo sviluppo locale.
# Su Vercel imposta le variabili nel pannello Project → Settings → Environment Variables.

# Seed dati demo nel database produzione (solo sviluppo / demo interna).
# Valori accettati: "true" | lasciare vuoto / "false"
# In produzione lasciare disattivato: la modalità Demo usa un database IndexedDB separato.
VITE_DEMO_SEED=false
